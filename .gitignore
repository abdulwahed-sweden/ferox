# ==========================================
# Ferox C2 Operational Data (CRITICAL)
# ==========================================
# Session data - NEVER COMMIT!
session_data/
sessions/
**/session_data/

# Workspace cache
workspace_cache/
.workspace/

# Audit trails - May contain sensitive operational data
audit/
**/audit/

# Captured credentials - HIGHLY SENSITIVE!
credentials/
creds/
loot/
**/loot/

# Generated payloads - Potential malware
payloads/
generated_payloads/
*.payload

# Operation results - May contain target data
results/
reports/
output/
scans/
dumps/

